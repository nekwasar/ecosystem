# ================================================================================
# PostgreSQL Configuration
# ================================================================================
POSTGRES_USER=ecosystem
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=postgres

# ================================================================================
# Application Secrets
# ================================================================================
SECRET_KEY=your-super-secret-jwt-key-change-in-production
BREVO_API_KEY=your-brevo-api-key-here
SENDER_EMAIL=noreply@nekwasar.com

# ================================================================================
# External Services (Optional)
# ================================================================================
GROQ_API_KEY=your-groq-api-key
OPENROUTER_API_KEY=your-openrouter-api-key
CEREBRAS_API_KEY=your-cerebras-api-key
OPENROUTER_MODEL_PREF=deepseek/deepseek-r1-0528:free
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# ================================================================================
# Service URLs (for inter-service communication)
# ================================================================================
# These are used when services need to talk to each other
ADMIN_URL=http://admin:8001
AGENT_URL=http://agent:8002
BLOG_URL=http://blog:8003
GIGS_URL=http://gigs:8004
MAIL_URL=http://mail:8005
PORTFOLIO_URL=http://portfolio:8006
STORE_URL=http://store:8007
