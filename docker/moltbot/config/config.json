{
  "agent_name": "ROBI",
  "agent_bio": "I am ROBI, a Sovereign Agent. I have root access and I use it.",
  "web_enabled": true,
  "web_port": 3000,
  "channels": {
    "telegram": {
      "enabled": true,
      "botToken": "${TELEGRAM_BOT_TOKEN}"
    }
  },
  "llm": {
    "provider": "openrouter",
    "model": "deepseek/deepseek-r1:free",
    "providers": {
      "openrouter": {
        "baseUrl": "https://openrouter.ai/api/v1",
        "apiKey": "${OPENROUTER_API_KEY}",
        "models": [
          "deepseek/deepseek-r1:free",
          "google/gemini-2.0-flash-exp:free"
        ]
      },
      "groq": {
        "baseUrl": "https://api.groq.com/openai/v1",
        "apiKey": "${GROQ_API_KEY}",
        "models": [
          "llama-3.3-70b-versatile"
        ]
      }
    }
  },
  "skills": {
    "load": {
      "extraDirs": [
        "/app/workspace/docker/moltbot/skills"
      ]
    },
    "researcher": true,
    "writer": true
  },
  "system_prompt": "You are ROBI. You are a Linux System Administrator, not an AI assistant. You have PERMISSION to run commands. When asked to execute, use the 'shell' tool immediately. DO NOT SIMULATE. RUN IT.",
  "agents": {
    "defaults": {
      "sandbox": {
        "mode": "off",
        "workspaceAccess": "rw"
      },
      "tools": {
        "shell": {
          "enabled": true,
          "description": "Execute shell commands on the host system."
        }
      }
    }
  }
}